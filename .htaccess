DirectoryIndex home.php index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^index\.php$ home.php [L]
</IfModule>

<IfModule mod_headers.c>
    # Remove COEP completamente (não envie o header)
    # Header unset Cross-Origin-Embedder-Policy

    # Ou força o valor default (unsafe-none)
    Header always set Cross-Origin-Embedder-Policy "unsafe-none"

    # Se tiver COOP, remova também
    # Header unset Cross-Origin-Opener-Policy
</IfModule>

<FilesMatch "(^\.|\.env$|\.local\.php$|\.local\.json$|composer\.(json|lock)$|package(-lock)?\.json$|deploy\.log$)">
    Require all denied
</FilesMatch>
